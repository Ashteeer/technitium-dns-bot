#!/usr/bin/env bash
# ============================================================================
#  ttbot — управление сервисом Technitium DNS spoofing bot
#
#     ttbot --version            показать установленную версию
#     ttbot --update [версия]    обновить с GitHub (по умолчанию — последняя)
#     ttbot --reload             перекачать списки и применить все правила
#     ttbot --flush [-y]         удалить ВСЕ правила и зоны, сбросить состояние
#     ttbot start | stop | restart
#     ttbot status               статус сервиса
#     ttbot logs [N]             логи (по умолчанию следим за хвостом)
#     ttbot --help
#
#  Привилегированные команды при запуске не от root перезапускаются через sudo.
# ============================================================================
set -euo pipefail

REPO="Ashteeer/technitium-dns-bot"
INSTALL_DIR="/opt/technitium-bot"
SERVICE="technitium-bot"
VENV="$INSTALL_DIR/venv"
PY="$VENV/bin/python"
CONFIG="$INSTALL_DIR/config.yaml"
SELF="ttbot"

usage() {
    cat <<EOF
ttbot — управление сервисом Technitium DNS spoofing bot

  ttbot --version            показать установленную версию
  ttbot --update [версия]    обновить с GitHub (по умолчанию — последняя)
  ttbot --reload             перекачать списки и заново применить все правила
  ttbot --flush [-y]         удалить ВСЕ правила и зоны, сбросить состояние
  ttbot start | stop | restart
  ttbot status               статус сервиса
  ttbot logs [N]             логи (следим за хвостом, N строк истории)
  ttbot --help               эта справка

Привилегированные команды (start/stop/restart/update/reload/flush/logs) при
запуске не от root автоматически перезапускаются через sudo.
EOF
}

show_version() {
    if [ -x "$PY" ]; then
        "$PY" -m ttbot --version
    else
        echo "$SELF: не установлено (нет $VENV)"
        exit 1
    fi
}

do_update() {
    local ver="${1:-}"
    echo "Обновление technitium-bot${ver:+ до версии $ver}…"
    curl -fsSL "https://raw.githubusercontent.com/$REPO/main/INSTALL.sh" | bash -s -- ${ver:+"$ver"}
}

# Запустить одноразовую операцию бота, гарантированно вернув сервис в строй.
run_oneshot() {  # $1 = flush|reload
    local action="$1" rc=0
    systemctl stop "$SERVICE" || true
    "$PY" -m ttbot "--$action" --config "$CONFIG" || rc=$?
    systemctl start "$SERVICE"
    if [ "$rc" -eq 0 ]; then
        echo "${action^} завершён."
    else
        echo "${action^}: ошибка (код $rc)." >&2
    fi
    return "$rc"
}

do_flush() {
    local force="${1:-}"
    if [ "$force" != "-y" ] && [ "$force" != "--yes" ]; then
        if [ -r /dev/tty ]; then
            printf 'Удалить ВСЕ правила и зоны, сбросить состояние? [y/N]: ' > /dev/tty
            local ans=""
            IFS= read -r ans < /dev/tty || ans=""
            case "$ans" in
                y | Y | yes | YES | да) ;;
                *) echo "Отменено."; return 1 ;;
            esac
        else
            echo "Требуется подтверждение: ttbot --flush -y" >&2
            return 1
        fi
    fi
    run_oneshot flush
}

main() {
    local cmd="${1:-help}"

    case "$cmd" in
        start | stop | restart | --update | update | --reload | reload | --flush | flush | logs)
            if [ "$(id -u)" -ne 0 ]; then
                exec sudo -- "$0" "$@"
            fi
            ;;
    esac

    case "$cmd" in
        --version | -v | version) show_version ;;
        --update | update) do_update "${2:-}" ;;
        --reload | reload) run_oneshot reload ;;
        --flush | flush) do_flush "${2:-}" ;;
        start | stop | restart)
            systemctl "$cmd" "$SERVICE"
            systemctl is-active --quiet "$SERVICE" \
                && echo "$SERVICE: active" || echo "$SERVICE: not active"
            ;;
        status) systemctl status "$SERVICE" --no-pager ;;
        logs) journalctl -u "$SERVICE" -n "${2:-100}" -f ;;
        --help | -h | help) usage ;;
        *)
            echo "Неизвестная команда: $cmd" >&2
            usage
            exit 1
            ;;
    esac
}

main "$@"
